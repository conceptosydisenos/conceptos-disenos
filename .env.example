# ─────────────────────────────────────────────────────────────
# Sistema Integral Conceptos y Diseños — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# DATABASE (Neon PostgreSQL)
# IMPORTANT: Use the POOLER connection string — NOT the "Direct" one.
# Neon Console → Your project → Connection Details → Connection string → Pooled connection
DATABASE_URL=postgres://[user]:[password]@[pooler-host]/[database]?sslmode=require

# ─────────────────────────────────────────────────────────────
# CLERK AUTHENTICATION
# Clerk Dashboard → API Keys
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook secret for syncing Clerk users → Neon database
# Clerk Dashboard → Webhooks → Add endpoint → https://yourdomain.com/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_...

# Redirect URLs (keep as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─────────────────────────────────────────────────────────────
# GOOGLE OAUTH (via Clerk — no env vars needed here)
# ─────────────────────────────────────────────────────────────
# Google OAuth login is configured in Clerk Dashboard:
# Clerk Dashboard → User & Authentication → Social Connections → Google → Enable
# Clerk manages the OAuth flow — no GOOGLE_CLIENT_ID needed in this file.

# ─────────────────────────────────────────────────────────────
# VERCEL BLOB (invoice image storage)
# Vercel Dashboard → Storage → Create Blob Store → .env.local tab
# ─────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─────────────────────────────────────────────────────────────
# GEMINI FLASH (OCR for invoices)
# ─────────────────────────────────────────────────────────────
# Option A — Google AI Studio API Key (RECOMMENDED — simpler, what we use)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Option B — Vertex AI Service Account (alternative, more complex)
# Only use if you're on Google Cloud and need enterprise features.
# This is what GOOGLE_APPLICATION_CREDENTIALS is for — NOT required for AI Studio.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─────────────────────────────────────────────────────────────
# ANTHROPIC CLAUDE API [Fase 3 — Asistente Financiero]
# https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
