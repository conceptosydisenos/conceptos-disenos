# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────$

# DATABASE (Neon PostgreSQL)
# IMPORTANT: Use the POOLER connection string — NOT the "Direct" one.
# Neon Console → Your project → Connection Details → Connection string → Pooled connection
DATABASE_URL=postgresql://neondb_owner:npg_bzDCKfVe3kj1@ep-aged-breeze-ajtua594-pooler.c-3.us-east-2.aws.neon.tech/neon$

# ──────────────────────────────────────────────────────────$
# CLERK AUTHENTICATION
# Clerk Dashboard → API Keys
# ──────────────────────────────────────────────────────────$
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZnVua3ktYmlyZC03MC5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_7CFU7Mc2WN0671SpCNCO5nPxb6cxn6GlNfGz07RiSc

# Webhook secret for syncing Clerk users → Neon database
# Clerk Dashboard → Webhooks → Add endpoint → https://yourdomain.com/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_...

# Redirect URLs (keep as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

^G Get Help         ^O WriteOut         ^R Read File        ^Y Prev Pg          ^K Cut Text         ^C Cur Pos          
^X Exit             ^J Justify          ^W Where is         ^V Next Pg          ^U UnCut Text       ^T To Spell        
